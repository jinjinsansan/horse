{
  "name": "@horsebet/shared",
  "version": "1.0.0",
  "description": "Shared types and utilities for HorseBet",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "files": [
    "dist"
  ],
  "exports": {
    "./types/database.types": {
      "types": "./dist/types/database.types.d.ts",
      "default": "./dist/types/database.types.js"
    },
    "./types/business.types": {
      "types": "./dist/types/business.types.d.ts",
      "default": "./dist/types/business.types.js"
    },
    "./lib/supabase": {
      "types": "./dist/lib/supabase.d.ts",
      "default": "./dist/lib/supabase.js"
    },
    "./automation": {
      "types": "./dist/automation/index.d.ts",
      "default": "./dist/automation/index.js"
    },
    "./automation/ipat-voter": {
      "types": "./dist/automation/ipat-voter.d.ts",
      "default": "./dist/automation/ipat-voter.js"
    },
    "./automation/spat4-voter": {
      "types": "./dist/automation/spat4-voter.d.ts",
      "default": "./dist/automation/spat4-voter.js"
    },
    "./automation/odds-scraper": {
      "types": "./dist/automation/odds-scraper.d.ts",
      "default": "./dist/automation/odds-scraper.js"
    }
  },
  "typesVersions": {
    "*": {
      "types/*": [
        "dist/types/*"
      ],
      "lib/*": [
        "dist/lib/*"
      ],
      "automation": [
        "dist/automation/index.d.ts"
      ],
      "automation/*": [
        "dist/automation/*"
      ]
    }
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3",
    "playwright": "^1.56.1"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.84.0"
  }
}
